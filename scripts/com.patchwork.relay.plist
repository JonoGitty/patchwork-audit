<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.patchwork.relay</string>

    <key>ProgramArguments</key>
    <array>
        <string>__NODE_PATH__</string>
        <string>__PATCHWORK_CLI__</string>
        <string>relay</string>
        <string>start</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>UserName</key>
    <string>root</string>

    <key>StandardOutPath</key>
    <string>/Library/Patchwork/relay-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Library/Patchwork/relay-stderr.log</string>

    <key>WorkingDirectory</key>
    <string>/Library/Patchwork</string>

    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>

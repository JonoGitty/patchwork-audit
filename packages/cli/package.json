{
  "name": "patchwork-audit",
  "version": "0.1.0",
  "description": "The audit trail for AI coding agents",
  "type": "module",
  "bin": {
    "patchwork": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@patchwork/core": "workspace:*",
